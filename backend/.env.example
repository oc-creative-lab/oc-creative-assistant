# 本地 embedding 配置示例。
# 后端 PyInstaller 打包使用的 Python 解释器；换机器时改成本机环境路径。
PYTHON_BIN="python.exe"
OC_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OC_EMBEDDING_API_KEY=your-dashscope-api-key
OC_EMBEDDING_MODEL=text-embedding-v4
OC_EMBEDDING_DIMENSION=1024
# 是否打印 Chroma 增量同步和 embedding 调用细节；排查问题时改为 true。
OC_INDEXING_DEBUG_LOG=false

# 对话 LLM 配置（OpenRouter 等 OpenAI 兼容服务）；provider=mock 为离线桩。
OC_LLM_PROVIDER=openai
OC_LLM_BASE_URL=https://openrouter.ai/api/v1
OC_LLM_API_KEY=your-openrouter-api-key
OC_LLM_MODEL=deepseek/deepseek-chat

# 每轮 Agent 注入对话的检索上下文 token 上限；超过后按相关性裁剪。
OC_AGENT_CONTEXT_TOKEN_CAP=2000

# Web Search (Tavily) 配置。留空 API key 则 web_search 工具直接返回降级提示,
OC_WEB_SEARCH_PROVIDER=tavily
OC_WEB_SEARCH_API_KEY=
OC_WEB_SEARCH_TIMEOUT=10