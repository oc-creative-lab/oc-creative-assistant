# Local embedding configuration example.
# Python interpreter used for backend PyInstaller builds; point this at your local env on another machine.
PYTHON_BIN="python.exe"
OC_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OC_EMBEDDING_API_KEY=your-dashscope-api-key
OC_EMBEDDING_MODEL=text-embedding-v4
OC_EMBEDDING_DIMENSION=1024
# Log Chroma incremental sync and embedding call details; set to true when debugging.
OC_INDEXING_DEBUG_LOG=true

# Dev mode: stream detailed agent/graph errors to the frontend.
OC_DEV_MODE=true

# Chat LLM configuration (OpenRouter and other OpenAI-compatible services); provider=mock is an offline stub.
OC_LLM_PROVIDER=openai
OC_LLM_BASE_URL=https://openrouter.ai/api/v1
OC_LLM_API_KEY=your-openrouter-api-key
OC_LLM_MODEL=deepseek/deepseek-chat

# Max retrieval-context tokens injected per agent turn; trim by relevance when exceeded.
OC_AGENT_CONTEXT_TOKEN_CAP=2000

# Web Search (Tavily). Leave the API key empty and web_search returns a graceful fallback message.
OC_WEB_SEARCH_PROVIDER=tavily
OC_WEB_SEARCH_API_KEY=
OC_WEB_SEARCH_TIMEOUT=10