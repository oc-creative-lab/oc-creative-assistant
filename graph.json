{"project":{"id":"default-project","name":"星庭档案"},"nodes":[{"id":"char-airin","type":"character","nodeType":"character","title":"艾琳","content":"年轻的见习记录官，对王都隐藏的魔法痕迹异常敏感。","position":{"x":706.5453772102697,"y":-363.61469508849166},"meta":"角色 / 主角","typeLabel":"角色","tags":["角色","主角"],"status":"synced"},{"id":"char-mentor","type":"character","nodeType":"character","title":"导师","content":"曾经服务于王室档案馆，保留着关于古老契约的秘密。","position":{"x":5.737625734229965,"y":16.346536343625687},"meta":"角色 / 导师","typeLabel":"角色","tags":["角色","导师"],"status":"draft"},{"id":"world-capital","type":"worldbuilding","nodeType":"worldbuilding","title":"王都","content":"建在三层古城遗址上的都城，地下仍有未注销的旧魔法阵。","position":{"x":-18.564789674708052,"y":273.1304000080106},"meta":"世界观 / 城市","typeLabel":"世界观","tags":["世界观","城市"],"status":"synced"},{"id":"world-magic-rule","type":"worldbuilding","nodeType":"worldbuilding","title":"魔法规则","content":"所有术式都需要以真名或记忆作为锚点，代价会追溯到施术者。","position":{"x":420.0,"y":693.0651340996169},"meta":"世界观 / 规则","typeLabel":"设定","tags":["世界观","规则"],"status":"outdated"},{"id":"plot-first-meet","type":"plot","nodeType":"plot","title":"初遇事件","content":"艾琳在王都集市追查失窃档案，意外遇到伪装身份的导师。","position":{"x":412.647780273657,"y":274.12041599804934},"meta":"剧情 / 第一幕","typeLabel":"剧情","tags":["剧情","第一幕"],"status":"draft"},{"id":"plot-conflict-rise","type":"plot","nodeType":"plot","title":"冲突升级","content":"魔法阵被意外启动，王都地下遗址开始影响地表秩序。","position":{"x":760.0,"y":80.0},"meta":"剧情 / 冲突","typeLabel":"剧情","tags":["剧情","冲突"],"status":"draft"},{"id":"idea-memory-cost","type":"idea","nodeType":"idea","title":"记忆代价灵感","content":"如果真名魔法会改写记忆，角色每次施术都可能遗失一个重要关系。","position":{"x":82.02950440189076,"y":811.1618791472132},"meta":"灵感 / 魔法","typeLabel":"灵感","tags":["灵感","魔法"],"status":"draft"},{"id":"research-archive-source","type":"research","nodeType":"research","title":"档案馆资料来源","content":"记录王室档案馆公开职责、隐藏职责和旧契约材料的参考摘要。","position":{"x":840.0,"y":345.7142857142857},"meta":"资料 / 档案","typeLabel":"资料","tags":["资料","档案"],"status":"draft"},{"id":"structure-act-one","type":"structure","nodeType":"structure","title":"第一幕结构整理","content":"把失窃档案、初遇导师、魔法阵异动串成第一幕的因果链。","position":{"x":1100.0,"y":80.0},"meta":"结构 / 剧情","typeLabel":"结构整理","tags":["结构","剧情"],"status":"draft"},{"id":"char-draft-1778245973174-10","type":"character","nodeType":"character","title":"艾琳的能力来源","content":"当前节点只描述了‘对魔法痕迹异常敏感’，但未说明能力来源，这关系到角色设定的一致性和后续剧情走向。","position":{"x":-61.50130255429157,"y":547.2279015435072},"meta":"AI 建议 / Inspiration","typeLabel":"角色","tags":["AI 建议","Inspiration"],"status":"draft"},{"id":"plot-draft-1778245983778-11","type":"plot","nodeType":"plot","title":"艾琳的过去事件","content":"理解她为何成为记录官、为何对魔法敏感，需要一段背景故事节点来支撑角色的行为动机。","position":{"x":-60.63250529624166,"y":709.7421473148947},"meta":"AI 建议 / Inspiration","typeLabel":"剧情","tags":["AI 建议","Inspiration"],"status":"draft"},{"id":"713d87f2bd1247e2a96710d40c8af66b","type":"character","nodeType":"character","title":"矮人铁匠·布罗尔","content":"王都老城区经营三代铁匠铺的矮人，铺子地窖意外打通了第二层古城遗址的旧魔法阵边缘。他试图用矮人符文封印裂口，但每敲一锤，自己的记忆就模糊一分。","position":{"x":1060.7894736842106,"y":651.6666666666667},"meta":"AI 建议","typeLabel":"角色节点","tags":["AI 建议"],"status":"synced"},{"id":"1c556b9784c84217b79feb01538f4a7c","type":"character","nodeType":"character","title":"埃迪","content":"一只小精灵，具体设定待补充。","position":{"x":80.0,"y":980.0},"meta":"AI 建议","typeLabel":"角色节点","tags":["AI 建议"],"status":"synced"},{"id":"31b1123418a14f7fbbfe6af69189f361","type":"character","nodeType":"character","title":"木匠·奥雷利亚诺","content":"王都老城区的木匠，手艺精湛，铺子就在矮人铁匠布罗尔的铁匠铺隔壁。两个手艺人日常互相照应——布罗尔要换锤柄会去找他，奥雷利亚诺要修铁质榫头也会往铁匠铺跑。","position":{"x":496.5366096181812,"y":945.0322074907707},"meta":"AI 建议","typeLabel":"角色节点","tags":["AI 建议"],"status":"synced"},{"id":"b50eaed5f1f74afebd96855845a11550","type":"plot","nodeType":"plot","title":"布罗尔遗忘裂口","content":"布罗尔反复敲击符文封印后，记忆加速流失，终于彻底忘了裂口的存在，也忘了自己为什么在地窖里敲符文。铁匠铺恢复日常运转，但地窖里的裂口无人维护，封印开始松动，裂口缓慢扩大。","position":{"x":543.6997764434177,"y":1097.3452464347965},"meta":"AI 建议","typeLabel":"剧情节点","tags":["AI 建议"],"status":"synced"},{"id":"1d4a45bcfb674c5eb1beff497d1da709","type":"worldbuilding","nodeType":"worldbuilding","title":"王都异常现象扩散","content":"裂口扩大后，王都老城区开始出现一系列异常：墙壁渗水银、钟表倒走、地下传来低沉嗡鸣、猫狗绕开铁匠铺街区。普通人当怪谈议论，但魔法敏感体质的人能感知到更深的不安。","position":{"x":539.051969071131,"y":531.9793619982005},"meta":"AI 建议","typeLabel":"世界观节点","tags":["AI 建议"],"status":"synced"},{"id":"9611cb48f7384728b2f591ccc2fd9202","type":"plot","nodeType":"plot","title":"艾琳独自追查撞上裂口","content":"艾琳凭借魔法敏感体质感知到老城区的异常，带着埃迪一路追查到布罗尔的铁匠铺。但布罗尔已遗忘裂口，面对追问只能茫然否认，两人之间产生信任裂痕。艾琳在没有导师解释古老契约背景的情况下，可能凭直觉用错误方式触碰魔法阵，导致裂口加速扩大。","position":{"x":1069.4974995409168,"y":451.9704944856744},"meta":"AI 建议","typeLabel":"剧情节点","tags":["AI 建议"],"status":"synced"},{"id":"0384b4b295d04cdf85e8b38cdf756f2c","type":"character","nodeType":"character","title":"维拉·暗影监察官","content":"王室档案馆的秘密监察官，和艾琳同期入职但走向了完全相反的方向。她发现了古老契约的另一面——那不是封印，而是力量源泉。她盯上了古城遗址的裂口，试图从中获取禁忌力量。性格冷酷务实，视艾琳的天真理想为最大障碍，两人从档案馆内部的明争暗斗延伸到对古城秘密的争夺。","position":{"x":-37.06931787822186,"y":111.5097666011772},"meta":"AI 建议","typeLabel":"角色节点","tags":["AI 建议"],"status":"synced"},{"id":"dbb99d3d1ba64f9f9ae55f81e4a21e5c","type":"character","nodeType":"character","title":"魔王·墨里斯","content":"沉睡在古城遗址裂口另一端的古老存在，真实身份是第二纪元末期被封印的毁灭领主。裂口扩大导致封印松动，他的意识开始渗透到王都现实层。与维拉不同——维拉是想利用裂口获取力量的人类野心家，而墨里斯本身就是裂口的源头。他视艾琳为威胁，因为艾琳的魔法敏感体质让她成为唯一可能重新加固封印的人。性格傲慢、耐心、善于蛊惑，目前只能通过梦境和低语影响现实。","position":{"x":45.388902213265425,"y":390.56726398375974},"meta":"AI 建议","typeLabel":"角色节点","tags":["AI 建议"],"status":"synced"}],"edges":[{"id":"edge-airin-first-meet","source":"char-airin","target":"plot-first-meet","label":"参与","relationType":"belongs_to","sourceHandle":"right","targetHandle":"left","type":"smoothstep","animated":false},{"id":"edge-mentor-first-meet","source":"char-mentor","target":"plot-first-meet","label":"推动","relationType":"causes","sourceHandle":"right","targetHandle":"left","type":"smoothstep","animated":false},{"id":"edge-capital-first-meet","source":"world-capital","target":"plot-first-meet","label":"发生于","relationType":"belongs_t